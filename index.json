      "id": "b5fbe985-afc0-4734-965b-fdadb23e1f86",
      "file_name": "sheenhoong_之间间隔.json",
      "version": 5,
      "category": "Public",
      "name": {
        "en": "之间间隔",
        "zh": "之间间隔"
      },
      "remarks": {
        "en": "用于计算栏杆、栅栏等非对称排布的间距。支持最左与最右留空距离不相等、有无端柱的情况。输入参数说明：[总长度]为安装总跨度；[左侧留空]与[右侧留空]为两端边缘到第一根栏杆的净空距离（若无则填0）；[栏杆数量]为中间放置的单体栏杆总数；[单根宽度]为单根栏杆自身的材料厚度。公式自动处理了除以0保护与负数净长保护。",
        "zh": "用于计算栏杆、栅栏等非对称排布的间距。支持最左与最右留空距离不相等、有无端柱的情况。输入参数说明：[总长度]为安装总跨度；[左侧留空]与[右侧留空]为两端边缘到第一根栏杆的净空距离（若无则填0）；[栏杆数量]为中间放置的单体栏杆总数；[单根宽度]为单根栏杆自身的材料厚度。公式自动处理了除以0保护与负数净长保护。"
      },
      "factors": [
        {
          "unit": null,
          "defaultValue": 0,
          "id": "栏杆数量",
          "label": {
            "en": "栏杆数量",
            "zh": "栏杆数量"
          }
        },
        {
          "unit": null,
          "defaultValue": 0,
          "id": "总长度",
          "label": {
            "en": "总长度",
            "zh": "总长度"
          }
        },
        {
          "unit": null,
          "defaultValue": 0,
          "id": "左侧留空",
          "label": {
            "en": "左侧留空",
            "zh": "左侧留空"
          }
        },
        {
          "unit": null,
          "defaultValue": 0,
          "id": "右侧留空",
          "label": {
            "en": "右侧留空",
            "zh": "右侧留空"
          }
        },
        {
          "unit": null,
          "defaultValue": 0,
          "id": "单根宽度",
          "label": {
            "en": "单根宽度",
            "zh": "单根宽度"
          }
        }
      ],
      "expression": "{@C = if([栏杆数量]<=0,1,[栏杆数量]+1)}\n{@S = if(@W>0,@W/@C,0)}\n{@W = [总长度]-[左侧留空]-[右侧留空]-([栏杆数量]*[单根宽度])}\n净分配长度：{@W}&间隔数量：{@C}&最终理论间距：{@S}",
      "author": "sheenhoong",
      "authorUid": "uladk5rR9kOZzNudZIV2ISYvWaD2",
      "rating": 9,
      "download_count": 1
    },
    {
      "id": "eb0cf22f-19fc-450d-8a1a-5bdf5f78b7b5",
      "file_name": "sheenhoong_固定利率贷款计算器.json",
      "version": 1,
      "category": "Public",
      "name": {
        "en": "固定利率贷款计算器",
        "zh": "固定利率贷款计算器"
      },
      "remarks": {
        "en": "本公式用于计算固定利率（Fix Rate）贷款的分期详情。适用场景包括固定利息的汽车贷款、商业设备贷或特定工程分期。输入说明：[总贷款]填写项目或物件总价；[首付]填写已付的Deposit金额；[贷款年限]填写整年数；[年利率]可直接输入百分比数字（如5.5）或小数（如0.055）。输出结果包含实际贷款额、总利息、总还款额及每月月供，数值均保留2位小数。",
        "zh": "本公式用于计算固定利率（Fix Rate）贷款的分期详情。适用场景包括固定利息的汽车贷款、商业设备贷或特定工程分期。输入说明：[总贷款]填写项目或物件总价；[首付]填写已付的Deposit金额；[贷款年限]填写整年数；[年利率]可直接输入百分比数字（如5.5）或小数（如0.055）。输出结果包含实际贷款额、总利息、总还款额及每月月供，数值均保留2位小数。"
      },
      "factors": [
        {
          "unit": null,
          "defaultValue": 0,
          "id": "总贷款",
          "label": {
            "en": "总贷款",
            "zh": "总贷款"
          }
        },
        {
          "unit": null,
          "defaultValue": 0,
          "id": "首付",
          "label": {
            "en": "首付",
            "zh": "首付"
          }
        },
        {
          "unit": null,
          "defaultValue": 0,
          "id": "年利率",
          "label": {
            "en": "年利率",
            "zh": "年利率"
          }
        },
        {
          "unit": null,
          "defaultValue": 0,
          "id": "贷款年限",
          "label": {
            "en": "贷款年限",
            "zh": "贷款年限"
          }
        }
      ],
      "expression": "{@D=[总贷款]-[首付]}{@I=if([年利率]>1,[年利率]/100,[年利率])}{@TI=@D*@I*[贷款年限]}{@TA=@D+@TI}{@M=@TA/([贷款年限]*12)}实际贷款额：{@D}&总利息：{round(@TI,2)}&总还款额：{round(@TA,2)}&每月还款额：{round(@M,2)}",
      "author": "sheenhoong",
      "authorUid": "uladk5rR9kOZzNudZIV2ISYvWaD2",
      "rating": 0,
      "download_count": 0
    },
